class Solution {
public:

    void revstr(string &s,int left,int right){
        while(left<right){
            swap(s[left],s[right]);
            left++;
            right--;
        }
    }

    string reverseStr(string s, int k) {
        int n=s.length();

        for(int i=0;i<n;i+=2*k){
            int left=i;
            int right=min(i+k-1,n-1);
            revstr(s,left,right);
        }

        return s;
    }
};
