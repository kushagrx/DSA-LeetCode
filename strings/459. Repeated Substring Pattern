class Solution {
public:
    bool solve(string substring,string& s){
        string temp="";
        int times=s.length()/substring.length();
        for(int i=0;i<times;i++){
            temp+=substring;
        }
        return temp==s;
    }

    bool repeatedSubstringPattern(string s) {
        int n=s.length();
        string subst="";

        for(int i=0;i<n;i++){
            subst.push_back(s[i]);
            if(n%subst.length()!=0) continue;
            if(n>subst.length()){
                if(solve(subst,s)) return true;
            }
        }
        return false;
    }
};
