class Solution {
public:
    bool isSubsequence(string s, string t) {
        int n=s.length();
        int m=t.length();
        int left=0,right=0;

        while(left<n && right<m){
            if(s[left]==t[right]){
                left++;
            }
            right++;
        }
        return left==n;
    }
};
