class Solution {
public:
    int canBeTypedWords(string text, string brokenLetters) {
        int res=0;
        unordered_map<char,int>broke; 
        for(char c:brokenLetters){
            broke[c]++;
        }

        int i=0;
        while(i<text.length()){
            unordered_map<char,int>word;
            bool canType=true;
            while(i<text.length()&&text[i]!=' '){
                word[text[i]]++;
                if(broke.count(text[i])){
                    canType=false;
                }
                i++;
            }
            if (canType) res++;
            i++;
        }
        return res;
    }
};
