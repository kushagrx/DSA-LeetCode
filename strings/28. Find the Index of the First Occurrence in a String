class Solution {
public:
    int strStr(string haystack, string needle) {
        int left=0;
        int right=0;
        int m=haystack.length();
        int n=needle.length();

        while(left<m){
            int idx=left;
            right=0;
            while(left<m && right<n && haystack[left]==needle[right]){
                left++;
                right++;
                if(right==n) return idx;
            }   
            left=idx+1;
        }
        return -1;
    }
};
