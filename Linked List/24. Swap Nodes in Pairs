class Solution {
public:
    ListNode* swapPairs(ListNode* head) {
        if(!head) return nullptr;
        ListNode* dummy=new ListNode(0);
        dummy->next=head;
        ListNode* prev=dummy;
        ListNode* curr=head;

        while(curr && curr->next){
            ListNode* ptr1=curr;
            ListNode* ptr2=curr->next;

            prev->next=ptr2;
            ptr1->next=ptr2->next;
            ptr2->next=ptr1;

            prev=ptr1;
            curr=ptr1->next;
        }
        return dummy->next;
    }
};
