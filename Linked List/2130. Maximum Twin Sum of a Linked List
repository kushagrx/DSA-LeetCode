class Solution {
public:
    int pairSum(ListNode* head) {
        int res=0;
        ListNode* left=head;
        ListNode* right=head;
        stack<int>st;

        while(right){
            st.push(right->val);
            right=right->next;
        }

        while(left&&!st.empty()){
            int sum=left->val+st.top();
            st.pop();
            res=max(res,sum);
            left=left->next;
        }
        return res;
    }
};
