class Solution {
public:
    ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {
        if(!list1 && !list2) return nullptr;
        if(!list1) return list2;
        if(!list2) return list1;
        ListNode* p1=list1;
        ListNode* p2=list2;
        ListNode* dummy=new ListNode(0);
        ListNode* curr=dummy;

        while(p1 && p2){
            if(p2->val<p1->val){
                curr->next=p2;
                p2=p2->next;
            }
            else{
                curr->next=p1;
                p1=p1->next;
            }
            curr=curr->next;
        }
        curr->next=p1?p1:p2;
        return dummy->next;
    }
};
