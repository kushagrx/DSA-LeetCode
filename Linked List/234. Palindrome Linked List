class Solution {
public:
    bool isPalindrome(ListNode* head) {
        stack<int>st;
        ListNode* slow=head;
        ListNode* fast=head;

        while(fast&&fast->next){
            st.push(slow->val);
            slow=slow->next;
            fast=fast->next->next;
        }

        if(fast) slow=slow->next;  //to handle odd no. of nodes

        while(slow){
            if(slow->val == st.top()){
                st.pop();
            }
            slow=slow->next;
        }

        return st.empty();

    }
};
