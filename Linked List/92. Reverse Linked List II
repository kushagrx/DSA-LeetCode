class Solution {
public:
    ListNode* revLL(ListNode* head, int end){
        ListNode* curr = head;
        ListNode* prev = nullptr;
        for(int i = 0; i < end; i++){
            ListNode* nxt = curr->next;
            curr->next = prev;
            prev = curr;     
            curr = nxt;     
        }
        head->next = curr; 
        return prev;      
    }

    ListNode* reverseBetween(ListNode* head, int left, int right) {
        if(!head || left == right) return head; //edge cases
        ListNode* dummy=new ListNode(0);  //in case we have of reverse the first node itself
        dummy->next = head;
        ListNode* prev = dummy;
        for(int i = 1; i < left; i++){
            prev = prev->next;
        }
        ListNode* leftNode = prev->next;
        prev->next = revLL(leftNode, right - left + 1); 
        ListNode* res = dummy->next;
        delete dummy;
        return res;
    }
};
