class Solution {
public:
    vector<int>dp;
    int n;
    int solve(string& s,int i){
        if(i==n) return 1;
        if(s[i]=='0') return 0;
        if(dp[i]!=-1) return dp[i];
        
        int ways=0;
        ways+=solve(s,i+1);
        if(i+1<n){
            int curr=(s[i]-'0')*10+(s[i+1]-'0');
            if(curr>=10 && curr<=26){
                ways+=solve(s,i+2);
            }
        }
        return dp[i]=ways;
    }
    int numDecodings(string s) {
        n=s.length();
        dp.assign(n,-1);
        return solve(s,0);
    }
};
