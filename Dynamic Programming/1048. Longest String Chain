class Solution {
public:
    int dp[1001][1001];
    int n;

    bool isPred(string& a, string& b){
        if(b.length()-a.length()!=1) return false;
        int i=0,j=0;
        bool skip=false;
        while(i<a.length()&&j<b.length()){
            if(a[i]==b[j]){
                i++; j++;
            }
            else{
                if(skip) return false;
                skip=true;
                j++;
            }
        }
        return true;
    }

    int solve(vector<string>& words,int prev,int idx){
        if(idx==n) return 0;
        if(prev!=-1 && dp[prev][idx]!=-1) return dp[prev][idx];
        int take=0;
        if(prev==-1 || isPred(words[prev],words[idx])){
            take=1+solve(words,idx,idx+1);
        }
        int skip=solve(words,prev,idx+1);
        return prev==-1?max(take,skip) : dp[prev][idx]=max(take,skip);
    }

    int longestStrChain(vector<string>& words) {
        sort(words.begin(), words.end(), [](string &a, string &b){
            return a.size() < b.size();
        });
        n=words.size();
        memset(dp,-1,sizeof(dp));
        return solve(words,-1,0);
    }
};
