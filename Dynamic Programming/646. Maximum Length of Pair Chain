class Solution {
public:
    int dp[1001][1001];
    int n;
    
    int solve(vector<vector<int>>& pairs,int prev,int idx){
        if(idx==n) return 0;
        if(dp[prev+1][idx]!=-1) return dp[prev+1][idx];

        int take=0;
        if(prev==-1||pairs[prev][1]<pairs[idx][0]){
            take=1+solve(pairs,idx,idx+1);
        }
        int skip=solve(pairs,prev,idx+1);

        return dp[prev+1][idx]=max(take,skip);
    }

    int findLongestChain(vector<vector<int>>& pairs) {
        n=pairs.size();
        memset(dp,-1,sizeof(dp));
        sort(pairs.begin(),pairs.end());
        return solve(pairs,-1,0);
    }
};
