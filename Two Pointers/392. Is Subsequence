class Solution {
public:
    bool isSubsequence(string s, string t) {
        int left=0,right=0;
        int n=s.length();
        int m=t.length();

        while(left<n && right<m){
            if(s[left]==t[right]){
                left++;
            }
            right++;
        }
        return left==n;
    }
};
