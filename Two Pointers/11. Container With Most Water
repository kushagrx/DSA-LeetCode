class Solution {
public:
    int maxArea(vector<int>& height) {
        int n=height.size();
        int left=0,right=n-1;
        int res=INT_MIN,area=0;
        while(left<right){
            int l=right-left;
            int b=min(height[right],height[left]);
            area=l*b;
            if(height[left]<height[right]){
                left++;
            }
            else{
                right--;
            }
            res=max(area,res);
        }
        return res;
    }
};
