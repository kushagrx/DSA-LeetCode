class Solution {
public:
    string removeKdigits(string num, int k) {
        if(num.length()==k) return "0";
        string res="";
        stack<char>monostack;

        for(char c:num){
            while(!monostack.empty()&& c<monostack.top() && k>0){
                monostack.pop();
                k--;
            }
            monostack.push(c);
        }
        while(k>0 && !monostack.empty()){
            monostack.pop();
            k--;
        }
        while(!monostack.empty()){
            res.push_back(monostack.top());
            monostack.pop();
        }
        reverse(res.begin(),res.end());

        int i=0;
        while(i<res.size()&&res[i]=='0'){
            i++;
        }

        res=res.substr(i);
        return res.empty()?"0":res;
    }
};
