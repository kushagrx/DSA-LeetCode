class Solution {
public:
    long long pickGifts(vector<int>& gifts, int k) {
        priority_queue<int> pq;
        long long res=0;

        for(auto it:gifts){
            pq.push(it);
        }

        while(k--){
            int maxel=pq.top();
            pq.pop();
            maxel=sqrt(maxel);
            pq.push(maxel);
        }

        while(!pq.empty()){
            res+=pq.top();
            pq.pop();
        }

        return res;
    }
};
