class Solution {
public:
    string frequencySort(string s) {
        string res="";
        unordered_map<char,int>mp;
        for(char c:s){
            mp[c]++;
        }
        priority_queue<pair<int,char>>pq;
        for(auto it:mp){
            pq.push({it.second,it.first});
        }
        while(!pq.empty()){
            auto curr=pq.top();
            pq.pop();
            res+=string(curr.first,curr.second);
        }
        return res;
    }
};
