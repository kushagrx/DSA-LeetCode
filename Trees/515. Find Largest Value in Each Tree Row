class Solution {
public:
    vector<int> largestValues(TreeNode* root) {
        vector<int>res;
        if(!root) return res;
        queue<TreeNode*>q;
        q.push(root);

        while(!q.empty()){
            vector<int>level;
            int n=q.size();
            for(int i=0;i<n;i++){
                TreeNode* curr=q.front();
                q.pop();
                if(curr->left) q.push(curr->left);
                if(curr->right) q.push(curr->right);

                level.push_back(curr->val);
            }
            
            int l=level.size()-1;
            sort(level.begin(),level.end());
            res.push_back(level[l]);
        }

        return res;
    }
};
