class Solution {
public:
    int mindiff=INT_MAX;
    TreeNode* prev=nullptr;

    void dfs(TreeNode* root){
        if(!root) return;
        dfs(root->left);
        if(prev){
            mindiff=min(mindiff,abs(root->val-prev->val));
        }
        prev=root;
        dfs(root->right);
    }

    int getMinimumDifference(TreeNode* root) {
        dfs(root);
        return mindiff;    
    }
};
