class Solution {
public:
    vector<vector<int>> zigzagLevelOrder(TreeNode* root) {
        vector<vector<int>>res;
        if(!root) return res;
        queue<TreeNode*>q;
        q.push(root);
        int flag=0;

        while(!q.empty()){
            int n=q.size();
            vector<int>level;
            for(int i=0;i<n;i++){
                TreeNode* curr=q.front();
                q.pop();

                if(curr->left) q.push(curr->left);
                if(curr->right) q.push(curr->right);

                level.push_back(curr->val);
            }
            if(flag==1){
                reverse(level.begin(),level.end());
                res.push_back(level);
                flag=1-flag;
            }
            else{
                res.push_back(level);
                flag=1-flag;
            }
            
        }

        return res;
    }
};
