class Solution {
public:
    int dfs(vector<vector<int>>& grid,int m,int n,int i,int j){
        if(i<0||j<0||i>=m||j>=n) return 0;
        if(grid[i][j]==1) return 1;

        grid[i][j]=1;    //marking the cell as visited
        int up=dfs(grid,m,n,i+1,j);
        int down=dfs(grid,m,n,i-1,j);
        int right=dfs(grid,m,n,i,j+1);
        int left=dfs(grid,m,n,i,j-1);

        return right&left&up&down;
    }

    int closedIsland(vector<vector<int>>& grid) {
        int m=grid.size();
        int n=grid[0].size();
        int num=0;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]==0){
                    num+=dfs(grid,m,n,i,j);
                }
            }
        }
        return num;
    }
};
