class Solution {
public:
    void dfs(vector<vector<int>>& rooms,vector<bool>&visited,int u){
        visited[u]=true;
        for(auto v:rooms[u]){
            if(!visited[v]){
                dfs(rooms,visited,v);
            }
        }
    }

    bool canVisitAllRooms(vector<vector<int>>& rooms) {
        int V=rooms.size();
        vector<bool>visited(V,false);
        dfs(rooms,visited,0);

        for(auto it:visited){
            if(!it) return false;
        }
        return true;
    }
};
