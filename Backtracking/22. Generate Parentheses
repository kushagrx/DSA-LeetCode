class Solution {
public:
    void solve(int n,int open,int close,vector<string>& res,string curr){
        if(curr.length()==n*2){
            res.push_back(curr);
            return;
        }

        if(open<n){
            solve(n,open+1,close,res,curr+"(");
        }
        if(close<open){
            solve(n,open,close+1,res,curr+")");
        }

    }

    vector<string> generateParenthesis(int n) {
        vector<string>res;
        solve(n,0,0,res,"");
        return res;
    }
};
