class Solution {
public:
    int longestOnes(vector<int>& nums, int k) {
        int n=nums.size();
        int left=0,zeros=0,cnt=0,right=0;

        while(right<n){
            if(nums[right]==0){
                zeros++;
            }
            while(zeros>k){
                if(nums[left]==0) zeros--;
                
                left++;
            }
            cnt=max(cnt,right-left+1);
            right++;
        }

        return cnt;
    }
};
