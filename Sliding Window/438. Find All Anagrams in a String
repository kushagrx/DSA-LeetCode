class Solution {
public:
    vector<int> findAnagrams(string s, string p) {
        vector<int>mp(26,0);
        vector<int>window(26,0);
        vector<int>res;
        for(char c:p){
            mp[c-'a']++;
        }
        int windowsize=p.length();
        int l=0,r=0;
        while(r<s.length()){
            window[s[r]-'a']++;
            if(r-l+1 > windowsize){
                window[s[l]-'a']--;
                l++;
            }
            if((r-l+1)==windowsize && window==mp){
                res.push_back(l);
            }
            r++;
        }
        return res;
    }
};
